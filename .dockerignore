# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# Virtual environments
.venv/
venv/
env/

# Environment files — never ship secrets inside the image
.env
.env.*
!.env.example

# Test files — not needed at runtime
backend/tests/
**/test_*.py
**/*_test.py

# Dev tooling
.git/
.gitignore
*.md
*.rst

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
