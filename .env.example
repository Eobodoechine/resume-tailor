# Copy this to .env and fill in your values
# Never commit .env to GitHub

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
ADMIN_EMAIL=enollc21@gmail.com

# URL where the app is publicly accessible — used in magic-link redirects (TD-13)
APP_URL=https://resume-tailor-ogop.onrender.com

# Comma-separated list of allowed CORS origins (TD-04)
# Include your Render URL and local dev URL
ALLOWED_ORIGINS=https://resume-tailor-ogop.onrender.com,http://localhost:8000

# Optional: Resend API key for custom email delivery
# When set, magic links are sent via Resend instead of Supabase's built-in mailer
# Supabase free plan = 2 emails/hour; Resend free plan = 100/day
RESEND_API_KEY=

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Optional: override the Claude model (default: claude-haiku-4-5-20251001)
CLAUDE_MODEL=

# Set to "development" for local dev (disables secure cookies over plain http)
ENV=development
